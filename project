// --- Minimal Input Component ---
const CleanInput = ({ value, onChange, className, placeholder, multiline = false }) => {
  const [isEditing, setIsEditing] = useState(false);
  const [tempValue, setTempValue] = useState(value);
  const inputRef = useRef(null);

  useEffect(() => setTempValue(value), [value]);

  const commit = useCallback(() => {
    setIsEditing(false);
    if (tempValue.trim() !== value) onChange(tempValue.trim() || placeholder);
  }, [tempValue, value, onChange, placeholder]);

  if (isEditing) {
    const props = {
      ref: inputRef,
      className: `bg-transparent border-b border-slate-300 outline-none w-full font-medium text-slate-800 ${className}`,
      value: tempValue,
      onChange: (e) => setTempValue(e.target.value),
      onBlur: commit,
      onKeyDown: (e) => {
        if (e.key === 'Enter' && !multiline) commit();
        if (e.key === 'Escape') { setTempValue(value); setIsEditing(false); }
      },
      autoFocus: true,
    };
    return multiline ? <textarea {...props} rows={1} className={`${props.className} resize-none`} /> : <input type="text" {...props} />;
  }

  return (
    <div onClick={(e) => { e.stopPropagation(); setIsEditing(true); }} className={`cursor-text truncate ${!value ? 'text-slate-300' : ''} ${className}`}>
      {value || placeholder}
    </div>
  );
};

// --- Journal Editor (Debounced Save) ---
const JournalEditor = ({ activeTask, updateTask }) => {
  const [log, setLog] = useState(activeTask.log || '');

  useEffect(() => { setLog(activeTask.log || ''); }, [activeTask.id, activeTask.log]);

  const handleBlur = () => {
     if (log !== activeTask.log) updateTask(activeTask.id, { log });
  };

  return (
     <textarea 
        className="w-full flex-1 min-h-[300px] bg-slate-50/50 border border-slate-200 rounded-xl p-5 text-sm text-slate-700 leading-loose outline-none resize-none focus:bg-white focus:border-blue-400 focus:ring-2 focus:ring-blue-50 transition-all custom-scroll"
        placeholder="수식 유도, 시뮬레이션 설정값, 논리적 근거를 기록하십시오 (LaTeX 호환 포맷 지원)."
        value={log}
        onChange={(e) => setLog(e.target.value)}
        onBlur={handleBlur}
     />
  );
};

// --- Sub Component: Scheduler Board ---
const SchedulerBoard = ({ tasks, blocks, setBlocks, updateTask }) => {
  const [dragState, setDragState] = useState(null);
  const [localBlocks, setLocalBlocks] = useState(blocks);
  const gridRef = useRef(null);

  useEffect(() => { if (!dragState) setLocalBlocks(blocks); }, [blocks, dragState]);

  const handleDragStart = (e, taskId, checkpointId) => {
    e.dataTransfer.setData('application/json', JSON.stringify({ taskId, checkpointId }));
    e.dataTransfer.effectAllowed = 'copy';
  };

  const handleDrop = (e, dayIdx) => {
    e.preventDefault();
    try {
      const data = JSON.parse(e.dataTransfer.getData('application/json'));
      if (!data.taskId || !data.checkpointId) return;
      
      const rect = e.currentTarget.getBoundingClientRect();
      let start = snap((e.clientY - rect.top) / HOUR_HEIGHT);
      if (start < 0) start = 0;
      if (start > 23) start = 23;
      
      setBlocks(prev => [...prev, { 
        id: `b${Date.now()}`, taskId: data.taskId, checkpointId: data.checkpointId, day: dayIdx, start, end: Math.min(start + 1.5, 24) 
      }]);
    } catch (err) { console.error("Invalid drop data"); }
  };

  const handleMouseDown = (e, block, action) => {
    if (e.button !== 0) return;
    e.stopPropagation();
    setDragState({ action, blockId: block.id, startY: e.clientY, originalStart: block.start, originalEnd: block.end, originalDay: block.day });
  };

  const handleMouseMove = useCallback((e) => {
    if (!dragState) return;
    setLocalBlocks(prev => prev.map(b => {
      if (b.id !== dragState.blockId) return b;
      const deltaTime = snap((e.clientY - dragState.startY) / HOUR_HEIGHT);

      if (dragState.action === 'resize') {
        let end = dragState.originalEnd + deltaTime;
        return { ...b, end: Math.min(Math.max(b.start + SNAP_STEP, end), 24) };
      }
      if (dragState.action === 'move') {
        const dur = dragState.originalEnd - dragState.originalStart;
        let start = dragState.originalStart + deltaTime;
        let end = start + dur;
        let day = dragState.originalDay;

        if (gridRef.current) {
          const rect = gridRef.current.getBoundingClientRect();
          const colWidth = (rect.width - 48) / 7;
          const relX = e.clientX - rect.left + gridRef.current.scrollLeft - 48;
          if (relX >= 0 && relX <= rect.width - 48) day = Math.max(0, Math.min(6, Math.floor(relX / colWidth)));
        }

        if (start < 0) { start = 0; end = dur; }
        else if (end > 24) { end = 24; start = 24 - dur; }
        return { ...b, start, end, day };
      }
      return b;
    }));
  }, [dragState]);

  const handleMouseUp = useCallback(() => {
    if (dragState) {
       setBlocks(localBlocks);
       setDragState(null);
    }
  }, [dragState, localBlocks, setBlocks]);

  useEffect(() => {
    if (dragState) {
      window.addEventListener('mousemove', handleMouseMove);
      window.addEventListener('mouseup', handleMouseUp);
    }
    return () => {
      window.removeEventListener('mousemove', handleMouseMove);
      window.removeEventListener('mouseup', handleMouseUp);
    };
  }, [dragState, handleMouseMove, handleMouseUp]);

  return (
    <div className="flex h-full bg-white border border-slate-200 rounded-2xl overflow-hidden shadow-sm">
      <div className="w-72 bg-slate-50/50 border-r border-slate-100 flex flex-col shrink-0">
        <div className="p-4 border-b border-slate-100 bg-white">
          <h3 className="text-[11px] font-bold text-slate-500 uppercase tracking-widest">Time Allocations</h3>
          <p className="text-[10px] text-slate-400 mt-1">세부 항목을 우측 시간표로 드래그</p>
        </div>
        <div className="flex-1 overflow-y-auto p-4 space-y-6 custom-scroll">
          {tasks.map(task => {
             const progress = task.checkpoints.length === 0 ? 0 : Math.round((task.checkpoints.filter(c=>c.done).length / task.checkpoints.length) * 100);
             if (progress === 100 && task.checkpoints.length > 0) return null;

             return (
              <div key={task.id} className="flex flex-col gap-2">
                <div className="text-[11px] font-black text-slate-700 tracking-tight flex items-center justify-between border-b border-slate-200 pb-1.5 mb-1">
                  <span className="truncate">{task.title}</span>
                  <span className="text-[9px] font-mono text-slate-400 shrink-0 ml-2">{progress}%</span>
                </div>
                
                {task.checkpoints.length === 0 && (
                   <div className="text-[10px] text-slate-400 italic">세부 항목(Checkpoint)이 없습니다.</div>
                )}

                {task.checkpoints.map(cp => {
                   if(cp.done) return null;
                   return (
                     <div 
                        key={cp.id} 
                        draggable 
                        onDragStart={(e) => handleDragStart(e, task.id, cp.id)} 
                        className="bg-white border border-slate-200 p-2.5 rounded-lg cursor-grab active:cursor-grabbing hover:border-blue-400 hover:shadow-sm transition-all flex items-start gap-2 group"
                     >
                        <GripVertical size={14} className="text-slate-300 shrink-0 mt-0.5" />
                        <div className="text-xs font-medium text-slate-600 leading-snug">{cp.text}</div>
                     </div>
                   );
                })}
              </div>
             );
          })}
        </div>
      </div>

      <div className="flex-1 flex flex-col relative bg-white overflow-hidden">
        <div className="flex-1 overflow-auto custom-scroll" ref={gridRef}>
          <div className="min-w-[700px] h-full flex flex-col">
            <div className="flex border-b border-slate-100 bg-white sticky top-0 z-30 pl-12 shadow-sm">
              {DAYS.map(day => (
                <div key={day} className="flex-1 py-2 text-center border-l border-slate-50 first:border-l-0">
                  <span className="text-[10px] font-semibold text-slate-400 uppercase tracking-wider">{day}</span>
                </div>
              ))}
            </div>
            <div className="flex relative bg-slate-50/20" style={{ height: GRID_HEIGHT }}>
              <div className="w-12 shrink-0 border-r border-slate-100 bg-white relative z-20">
                {HOURS.map(hour => (
                  <div key={hour} className="absolute w-full flex justify-center -translate-y-1/2" style={{ top: timeToPx(hour) }}>
                    <span className="text-[9px] text-slate-300 font-mono">{hour}:00</span>
                  </div>
                ))}
              </div>
              {DAYS.map((_, dayIdx) => (
                <div key={dayIdx} className="flex-1 relative border-l border-slate-100/50 first:border-l-0" onDragOver={e => e.preventDefault()} onDrop={e => handleDrop(e, dayIdx)}>
                  {HOURS.map(hour => <div key={hour} className="absolute w-full border-t border-slate-100 pointer-events-none" style={{ top: timeToPx(hour), height: HOUR_HEIGHT }} />)}
                  
                  {localBlocks.filter(b => b.day === dayIdx).map(block => {
                    const task = tasks.find(t => t.id === block.taskId);
                    const cp = task?.checkpoints.find(c => c.id === block.checkpointId);
                    if (!task || !cp) return null;

                    return (
                      <div
                        key={block.id}
                        onDoubleClick={() => setBlocks(prev => prev.filter(b => b.id !== block.id))}
                        className={`absolute left-1 right-1 rounded-lg border flex flex-col overflow-hidden shadow-sm transition-all group ${cp.done ? 'bg-slate-100 border-slate-200 text-slate-500' : 'bg-blue-50 border-blue-200 text-blue-900 hover:shadow-md'}`}
                        style={{ top: timeToPx(block.start), height: timeToPx(block.end - block.start), zIndex: dragState?.blockId === block.id ? 50 : 10 }}
                      >
                        <div className="flex-1 p-2 cursor-move flex flex-col overflow-hidden relative" onMouseDown={e => handleMouseDown(e, block, 'move')}>
                          <div className={`text-[9px] font-bold uppercase tracking-tight truncate mb-1 ${cp.done ? 'text-slate-400' : 'text-blue-500/80'}`}>{task.title}</div>
                          
                          <div onMouseDown={(e) => e.stopPropagation()} className="flex items-start gap-1.5">
                             <input 
                               type="checkbox"
                               checked={cp.done}
                               onChange={(e) => {
                                 const updatedCps = task.checkpoints.map(c => c.id === cp.id ? { ...c, done: e.target.checked } : c);
                                 updateTask(task.id, { checkpoints: updatedCps });
                               }}
                               className={`mt-[1.5px] w-3 h-3 rounded cursor-pointer shrink-0 ${cp.done ? 'border-slate-300 text-slate-400' : 'border-blue-300 text-blue-600 focus:ring-blue-500'}`}
                             />
                             <div className="flex-1 min-w-0">
                               <CleanInput 
                                  value={cp.text} 
                                  onChange={(newText) => {
                                     const updatedCps = task.checkpoints.map(c => c.id === cp.id ? { ...c, text: newText } : c);
                                     updateTask(task.id, { checkpoints: updatedCps });
                                  }} 
                                  className={`text-[11px] font-bold leading-tight w-full ${cp.done ? 'line-through opacity-60 text-slate-500' : ''}`} 
                               />
                             </div>
                          </div>

                          <div className={`text-[9px] font-mono mt-auto flex items-center gap-1 ${cp.done ? 'opacity-50' : 'opacity-70'}`}><Clock size={8} /> {formatTime(block.start)} - {formatTime(block.end)}</div>
                          <button className="absolute top-1 right-1 p-1 hover:bg-black/10 rounded text-black/40 opacity-0 group-hover:opacity-100" onClick={(e) => { e.stopPropagation(); setBlocks(prev => prev.filter(b => b.id !== block.id)); }}><X size={10}/></button>
                        </div>
                        <div className={`h-2 w-full cursor-ns-resize shrink-0 flex items-center justify-center ${cp.done ? 'hover:bg-slate-200' : 'hover:bg-blue-200'}`} onMouseDown={e => handleMouseDown(e, block, 'resize')}>
                          <div className={`w-4 h-0.5 rounded-full ${cp.done ? 'bg-slate-300' : 'bg-blue-300'}`} />
                        </div>
                      </div>
                    );
                  })}
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  );
};


const App = () => {
  const [user, setUser] = useState(null);
  const [data, setData] = useState(DEFAULT_DATA);
  const [syncStatus, setSyncStatus] = useState('Connecting Firebase...');
  
  const [activeView, setActiveView] = useState('overview'); 
  const [activeTaskId, setActiveTaskId] = useState(null);
  const [isSidebarOpen, setIsSidebarOpen] = useState(true);

  useEffect(() => {
    if (!auth) return;
    const initAuth = async () => {
      try {
        if (typeof __initial_auth_token !== 'undefined' && __initial_auth_token) {
          await signInWithCustomToken(auth, __initial_auth_token);
        } else {
          await signInAnonymously(auth);
        }
      } catch (err) { console.error("Firebase Auth Error:", err); }
    };
    initAuth();
    const unsub = onAuthStateChanged(auth, setUser);
    return () => unsub();
  }, []);

  useEffect(() => {
    if (!user || !db) return;
    
    setSyncStatus('Fetching Cloud Data...');
    const docRef = doc(db, 'artifacts', appId, 'users', user.uid, 'projectState', 'main');
    
    const unsubscribe = onSnapshot(docRef, (docSnap) => {
      if (docSnap.exists()) {
        setData(docSnap.data());
      } else {
        setDoc(docRef, DEFAULT_DATA);
      }
      setSyncStatus('Cloud Synced');
    }, (error) => {
      console.error("Firestore Listen Error:", error);
      setSyncStatus('Sync Error');
    });

    return () => unsubscribe();
  }, [user]);

  const saveToCloud = useCallback((newData) => {
    if (!user || !db) return;
    setSyncStatus('Saving...');
    const docRef = doc(db, 'artifacts', appId, 'users', user.uid, 'projectState', 'main');
    setDoc(docRef, newData)
      .then(() => setSyncStatus('Cloud Synced'))
      .catch((err) => { console.error(err); setSyncStatus('Sync Error'); });
  }, [user]);

  const activeTask = useMemo(() => data.tasks.find(t => t.id === activeTaskId) || null, [data.tasks, activeTaskId]);
  const globalProgress = useMemo(() => {
    if (data.tasks.length === 0) return 0;
    const taskProgresses = data.tasks.map(t => t.checkpoints.length === 0 ? 0 : t.checkpoints.filter(c=>c.done).length / t.checkpoints.length);
    return Math.round((taskProgresses.reduce((sum, val) => sum + val, 0) / data.tasks.length) * 100);
  }, [data.tasks]);

  const updateData = (key, updater) => {
    setData(prev => {
      const nextVal = typeof updater === 'function' ? updater(prev[key]) : updater;
      const newData = { ...prev, [key]: nextVal };
      saveToCloud(newData);
      return newData;
    });
  };

  const updateTask = (id, updates) => updateData('tasks', tasks => tasks.map(t => t.id === id ? { ...t, ...updates } : t));
  const addTask = () => updateData('tasks', tasks => [...tasks, { id: `t${Date.now()}`, title: '새로운 시스템 모듈', log: '', checkpoints: [] }]);
  
  const deleteTask = (id) => {
    if(confirm("이 작업과 연계된 일정, 저널이 모두 삭제됩니다.")) {
      setData(prev => {
        const newData = {
          ...prev,
          tasks: prev.tasks.filter(t => t.id !== id),
          blocks: prev.blocks.filter(b => b.taskId !== id)
        };
        saveToCloud(newData);
        return newData;
      });
      if (activeTaskId === id) setActiveTaskId(null);
    }
  };

  const deleteCheckpoint = (taskId, cpId) => {
    setData(prev => {
      const newData = {
        ...prev,
        tasks: prev.tasks.map(t => t.id === taskId ? { ...t, checkpoints: t.checkpoints.filter(c => c.id !== cpId) } : t),
        blocks: prev.blocks.filter(b => b.checkpointId !== cpId)
      };
      saveToCloud(newData);
      return newData;
    });
  };

  return (
    <div className="flex h-screen w-full bg-[#f4f6f8] text-slate-800 font-sans overflow-hidden">
      
      <aside className={`fixed lg:static inset-y-0 left-0 z-50 bg-slate-900 text-slate-300 flex flex-col shrink-0 transition-all duration-300 ease-in-out ${isSidebarOpen ? 'w-56' : 'w-0 lg:w-16'} overflow-hidden`}>
        <div className="h-16 flex items-center justify-center border-b border-slate-800 shrink-0">
          <Cpu size={20} className="text-blue-400" />
        </div>
        <nav className="flex-1 flex flex-col py-6 space-y-2 px-3">
          <button onClick={() => setActiveView('overview')} className={`flex items-center gap-4 px-3 py-3 rounded-xl transition-all ${activeView === 'overview' ? 'bg-blue-600 text-white' : 'hover:bg-slate-800 hover:text-white'}`}>
            <LayoutDashboard size={18} className="shrink-0" /> 
            <span className={`text-xs font-semibold whitespace-nowrap transition-opacity ${isSidebarOpen ? 'opacity-100' : 'opacity-0 lg:hidden'}`}>Project Overview</span>
          </button>
          <button onClick={() => setActiveView('scheduler')} className={`flex items-center gap-4 px-3 py-3 rounded-xl transition-all ${activeView === 'scheduler' ? 'bg-blue-600 text-white' : 'hover:bg-slate-800 hover:text-white'}`}>
            <CalendarDays size={18} className="shrink-0" /> 
            <span className={`text-xs font-semibold whitespace-nowrap transition-opacity ${isSidebarOpen ? 'opacity-100' : 'opacity-0 lg:hidden'}`}>Time Scheduler</span>
          </button>
        </nav>
        <div className={`p-4 border-t border-slate-800 transition-opacity ${isSidebarOpen ? 'opacity-100' : 'opacity-0 lg:hidden'}`}>
           <div className="flex justify-between items-center text-[10px] uppercase tracking-wider mb-2 text-slate-400"><span>Yield</span> <span>{globalProgress}%</span></div>
           <div className="w-full bg-slate-800 h-1.5 rounded-full overflow-hidden"><div className="bg-blue-500 h-full transition-all" style={{width: `${globalProgress}%`}}/></div>
        </div>
      </aside>

      <main className="flex-1 flex flex-col min-w-0 h-full relative">
        <header className="h-16 flex items-center px-6 bg-white border-b border-slate-200 shrink-0 shadow-sm z-20">
          <button onClick={() => setIsSidebarOpen(!isSidebarOpen)} className="p-2 text-slate-400 hover:text-slate-800 transition-colors mr-4">
            <Menu size={18} />
          </button>
          <CleanInput value={data.projectName} onChange={v => updateData('projectName', v)} className="text-sm font-bold text-slate-800 max-w-sm" />
          
          <div className="ml-auto flex items-center gap-4">
            <div className="flex items-center gap-1.5 text-[10px] font-mono font-bold text-slate-400 px-3 py-1.5 bg-slate-50 rounded-full border border-slate-200">
               <Cloud size={12} className={syncStatus.includes('Error') ? 'text-red-500' : syncStatus.includes('Saving') ? 'text-blue-500 animate-pulse' : 'text-emerald-500'} />
               {syncStatus}
            </div>
          </div>
        </header>

        <div className="flex-1 overflow-hidden relative">
          {activeView === 'overview' && (
            <div className="absolute inset-0 flex p-6 gap-6 overflow-hidden bg-[#fafbfc]">
              
              <div className="w-full lg:w-1/2 flex flex-col h-full bg-white border border-slate-200 rounded-3xl overflow-hidden shadow-sm">
                <div className="p-6 border-b border-slate-100 flex justify-between items-center bg-slate-50/50">
                  <h2 className="text-sm font-bold text-slate-800">Task Breakdown</h2>
                  <button onClick={addTask} className="text-blue-600 hover:bg-blue-50 p-1.5 rounded-lg transition-colors"><Plus size={18}/></button>
                </div>
                <div className="flex-1 overflow-y-auto p-6 space-y-4 custom-scroll">
                  {data.tasks.map(task => {
                    const total = task.checkpoints.length;
                    const done = task.checkpoints.filter(c=>c.done).length;
                    const progress = total === 0 ? 0 : Math.round((done/total)*100);
                    return (
                      <div key={task.id} onClick={() => setActiveTaskId(task.id)} className={`group border rounded-2xl p-4 cursor-pointer transition-all ${activeTaskId === task.id ? 'border-blue-400 shadow-md bg-blue-50/20' : 'border-slate-200 hover:border-slate-300 hover:shadow-sm bg-white'}`}>
                        <div className="flex justify-between items-start mb-3">
                          <CleanInput value={task.title} onChange={v => updateTask(task.id, {title: v})} className={`text-sm font-bold w-full ${progress === 100 && total > 0 ? 'text-slate-400 line-through' : 'text-slate-800'}`} />
                          <button onClick={(e) => {e.stopPropagation(); deleteTask(task.id)}} className="opacity-0 group-hover:opacity-100 text-slate-300 hover:text-red-500 ml-3"><Trash2 size={16}/></button>
                        </div>
                        <div className="flex items-center gap-3">
                          <div className="flex-1 bg-slate-100 h-1.5 rounded-full overflow-hidden">
                            <div className="bg-blue-500 h-full transition-all" style={{width: `${progress}%`}}/>
                          </div>
                          <span className="text-[10px] font-mono font-medium text-slate-500 w-8 text-right">{done}/{total}</span>
                        </div>
                      </div>
                    );
                  })}
                </div>
              </div>

              {activeTask ? (
                <div className="hidden lg:flex w-1/2 flex-col h-full bg-white border border-slate-200 rounded-3xl overflow-hidden shadow-lg animate-in slide-in-from-right-8 duration-300">
                  <div className="p-6 border-b border-slate-100 bg-slate-50/50 flex justify-between items-center">
                    <h2 className="text-sm font-bold text-slate-800 truncate pr-4">{activeTask.title}</h2>
                    <button onClick={() => setActiveTaskId(null)} className="p-1 text-slate-400 hover:bg-slate-200 rounded-lg"><X size={18}/></button>
                  </div>
                  <div className="flex-1 overflow-y-auto p-6 custom-scroll space-y-8">
                    
                    <section>
                      <h3 className="text-[11px] font-bold text-slate-500 uppercase tracking-widest mb-4 flex items-center gap-2"><CheckSquare size={14}/> Sub-Checkpoints</h3>
                      <div className="space-y-2">
                        {activeTask.checkpoints.map((cp, idx) => (
                          <div key={cp.id} className="flex items-start gap-3 p-2 hover:bg-slate-50 rounded-lg group">
                            <input type="checkbox" checked={cp.done} onChange={(e) => { const n = [...activeTask.checkpoints]; n[idx].done = e.target.checked; updateTask(activeTask.id, {checkpoints: n}); }} className="mt-1 w-4 h-4 rounded border-slate-300 text-blue-600 focus:ring-blue-500 cursor-pointer" />
                            <CleanInput value={cp.text} onChange={v => { const n = [...activeTask.checkpoints]; n[idx].text = v; updateTask(activeTask.id, {checkpoints: n}); }} className={`text-xs w-full mt-0.5 ${cp.done ? 'text-slate-400 line-through' : 'text-slate-700'}`} />
                            <button onClick={() => deleteCheckpoint(activeTask.id, cp.id)} className="opacity-0 group-hover:opacity-100 text-slate-300 hover:text-red-500"><X size={14}/></button>
                          </div>
                        ))}
                        <button onClick={() => updateTask(activeTask.id, {checkpoints: [...activeTask.checkpoints, {id: `c${Date.now()}`, text: "신규 검증 사항", done: false}]})} className="text-xs font-semibold text-blue-600 hover:text-blue-800 mt-2 flex items-center gap-1 pl-1"><Plus size={14}/> 항목 추가</button>
                      </div>
                    </section>

                    <section className="flex flex-col flex-1">
                      <h3 className="text-[11px] font-bold text-slate-500 uppercase tracking-widest mb-4 flex items-center gap-2"><FileText size={14}/> Engineering Journal</h3>
                      <JournalEditor activeTask={activeTask} updateTask={updateTask} />
                    </section>

                  </div>
                </div>
              ) : (
                <div className="hidden lg:flex w-1/2 flex-col justify-center items-center text-slate-400 bg-white/50 border border-slate-200 border-dashed rounded-3xl">
                  <FileText size={48} strokeWidth={1} className="mb-4 text-slate-300"/>
                  <p className="text-sm font-medium">좌측에서 태스크를 선택하여 상세 문서를 편집하십시오.</p>
                </div>
              )}
            </div>
          )}

          {activeView === 'scheduler' && (
            <div className="absolute inset-0 p-6 bg-[#fafbfc]">
              <SchedulerBoard tasks={data.tasks} blocks={data.blocks} setBlocks={b => updateData('blocks', b)} updateTask={updateTask} />
            </div>
          )}
        </div>
      </main>
      
      <style>{`
        .custom-scroll::-webkit-scrollbar { width: 5px; height: 5px; }
        .custom-scroll::-webkit-scrollbar-track { background: transparent; }
        .custom-scroll::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 10px; }
        .custom-scroll::-webkit-scrollbar-thumb:hover { background: #94a3b8; }
        input[type="checkbox"] { accent-color: #2563eb; }
      `}</style>
    </div>
  );
};

export default App;
